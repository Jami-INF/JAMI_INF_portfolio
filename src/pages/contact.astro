---
import Base from '../layouts/Base.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Heading from '../components/Heading.astro';
import Label from '../components/Label.astro';
import Button from '../components/Button.astro';
import { SITE } from '../consts';

const links = [
  { label: 'Email', value: SITE.email, href: `mailto:${SITE.email}`, ext: false },
  { label: 'GitHub', value: 'github.com/jami-inf', href: SITE.github, ext: true },
  { label: 'LinkedIn', value: 'Jami Infante', href: SITE.linkedin, ext: true },
];
---

<Base
  title="Contact"
  description="Contacter Jami Infante par email, GitHub ou LinkedIn."
>
  <section class="mx-auto max-w-6xl px-4 py-16">
    <SectionHeading number="04" title="Contact" as="h1" />

    <Heading as="p" size="lg" class="mt-10">
      Une opportunité, une question technique<span class="text-accent">,</span><br />ou un retour sur un projet<span class="text-accent">?</span>
    </Heading>

    <p class="mt-8 max-w-2xl leading-relaxed text-ink/80">
      Actuellement en poste, j'étudie les opportunités - CDI, région de
      Clermont-Ferrand ou télétravail. Le plus simple reste l'email : je réponds
      sous 48 h. Pour voir du code, GitHub&nbsp;; pour le parcours, LinkedIn.
    </p>

    <Label as="p" muted size="xs" class="mt-6 flex items-center gap-2 tracking-wide">
      <span class="h-2 w-2 shrink-0 bg-accent" aria-hidden="true"></span>
      Ouvert aux opportunités - {SITE.location}
    </Label>

    <ul class="mt-12 divide-y-2 divide-line border-2 border-line font-mono">
      {
        links.map((l) => (
          <li>
            <a
              href={l.href}
              target={l.ext ? '_blank' : undefined}
              rel={l.ext ? 'me noopener' : undefined}
              class="group flex flex-col gap-1 p-5 transition-colors duration-150 hover:bg-accent hover:text-accent-ink sm:flex-row sm:items-center sm:justify-between"
            >
              <Label size="xs" muted class="tracking-widest group-hover:text-accent-ink">
                {l.label}
              </Label>
              <span class="text-lg sm:text-2xl font-bold tracking-tight">
                {l.value} {l.ext ? '↗' : '→'}
              </span>
            </a>
          </li>
        ))
      }
    </ul>

    <div class="mt-12 flex flex-wrap gap-4">
      <Button href={`mailto:${SITE.email}`} variant="solid" size="lg">
        M'écrire un email →
      </Button>
      {/* À activer une fois le PDF déposé dans public/cv-jami-infante.pdf :
      <Button href="/cv-jami-infante.pdf" size="lg" external>
        Télécharger mon CV
      </Button>
      */}
    </div>
  </section>
</Base>
