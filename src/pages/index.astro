---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Heading from '../components/Heading.astro';
import Highlight from '../components/Highlight.astro';
import Label from '../components/Label.astro';
import Button from '../components/Button.astro';
import Tag from '../components/Tag.astro';
import { SITE } from '../consts';

// Stack mise en avant dans le hero - volontairement courte.
const heroStack = ['React', 'TypeScript', 'API REST', 'Docker', 'GitLab CI/CD', 'Linux'];

// Projets phares (featured) triés par ordre.
const all = await getCollection('projects');
const featured = all
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
---

<Base>
  <!-- ── HERO plein écran ─────────────────────────────────────────── -->
  <section
    class="mx-auto flex min-h-[calc(100dvh-4rem)] max-w-6xl flex-col justify-center px-4 py-16"
    aria-labelledby="hero-title"
  >
    <Label as="p" muted class="tracking-widest">Portfolio - 2026</Label>

    <Heading
      as="h1"
      id="hero-title"
      size="none"
      class="mt-4 leading-[0.85] tracking-tighter text-[18vw] sm:text-[15vw] lg:text-[12rem]"
    >
      Jami<br />Infante<span class="text-accent">.</span>
    </Heading>

    <p class="mt-8 max-w-2xl text-xl sm:text-2xl leading-snug">
      Développeur full-stack, <Highlight>4 ans d'expérience</Highlight>.
      Je conçois et livre des applications web, du back-end à l'interface.
    </p>

    <p class="mt-4 max-w-2xl leading-relaxed text-ink/80">
      Actuellement chez Emil Frey France, sur une marketplace B2B de pièces
      automobiles : Design, Maintenance WEB/API, DATA, e-commerce et CI/CD.&nbsp;<a
        href="/a-propos"
        class="link-brutal whitespace-nowrap">Mon parcours →</a>
    </p>

    <ul class="mt-6 flex max-w-2xl flex-wrap gap-2" aria-label="Stack principale">
      {heroStack.map((s) => <li><Tag label={s} /></li>)}
    </ul>

    <div class="mt-10 flex flex-wrap gap-4">
      <Button href="/projets" variant="solid">Voir les projets →</Button>
      <Button href="/contact">Me contacter</Button>
    </div>

    <Label as="p" muted size="xs" class="mt-10 flex items-center gap-2 tracking-wide">
      <span class="h-2 w-2 shrink-0 bg-accent" aria-hidden="true"></span>
      Ouvert aux opportunités - {SITE.location}
    </Label>
  </section>

  <!-- ── Projets phares ───────────────────────────────────────────── -->
  <section class="mx-auto max-w-6xl px-4 py-8" aria-label="Projets phares">
    <SectionHeading number="01" title="Projets phares" as="h2" />

    <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        featured.map((p) => (
          <ProjectCard
            number={String(p.data.order).padStart(2, '0')}
            title={p.data.title}
            description={p.data.description}
            stack={p.data.stack}
            image={p.data.image}
            href={`/projets/${p.id}`}
            date={p.data.date}
            ai={p.data.ai}
          />
        ))
      }
    </div>

    <div class="mt-8 border-t-2 border-line pt-4">
      <a href="/projets" class="link-brutal font-mono text-sm uppercase">
        Tous les projets →
      </a>
    </div>
  </section>
</Base>
