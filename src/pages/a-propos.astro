---
import Base from '../layouts/Base.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ExperienceCard from '../components/ExperienceCard.astro';
import PassionCard from '../components/PassionCard.astro';
import Highlight from '../components/Highlight.astro';
import Label from '../components/Label.astro';
import Heading from '../components/Heading.astro';
import Tag from '../components/Tag.astro';
import { experiences, skills, formation, passions } from '../data/about';
import { SITE } from '../consts';
---

<Base
  title="À propos"
  description="Parcours, expérience professionnelle et compétences de Jami Infante, développeur (4 ans d'expérience)."
>
  <section class="mx-auto max-w-6xl px-4 py-16">
    <SectionHeading number="02" title="À propos" as="h1" />

    <div class="mt-10">
      <p class="text-2xl sm:text-3xl leading-tight font-display">
        Je suis <Highlight>Jami Infante</Highlight>, développeur
        avec <Highlight>4 ans d'expérience</Highlight>. Je conçois et livre des
        applications web, du back-end à l'interface.
      </p>
    </div>

    <p class="mt-8 max-w-2xl leading-relaxed text-ink/80">
      Passé par l'alternance puis en poste, je construit des applications
      complètes en environnement pro - API, bases de données, interfaces - et je
      continue d'explorer de nouvelles technologies à travers mes projets
      personnels.
    </p>

    <p class="mt-4 max-w-2xl leading-relaxed text-ink/80">
      Je ne me suis jamais éloigné du milieu de l'informatique depuis le lycée,
      au moment où j'ai fait mes premiers projets personnels et scolaires. Cette
      curiosité m'a permis de découvrir les différents langages de programmation
      de manière autodidacte, avant même de m'orienter vers cette voie.
    </p>

    <p class="mt-4 max-w-2xl leading-relaxed text-ink/80">
      Ce que j'aime : résoudre des problèmes, automatiser ce qui peut l'être -
      tests, déploiements, documentation - et livrer des applications fiables.
    </p>

    <Label as="p" muted class="mt-6 tracking-wide">{SITE.location}</Label>

    <div class="mt-16">
      <SectionHeading number="02.1" title="Expérience" as="h2" />
      <ol class="mt-8 space-y-6">
        {experiences.map((exp) => <ExperienceCard experience={exp} />)}
      </ol>
    </div>

    <div class="mt-16">
      <SectionHeading number="02.2" title="Compétences" as="h2" />
      <div class="mt-8 grid gap-6 sm:grid-cols-2">
        {
          Object.entries(skills).map(([group, items]) => (
            <div class="border-2 border-line p-5">
              <Label as="h3" size="xs" muted class="font-bold tracking-widest">
                {group}
              </Label>
              <ul class="mt-4 flex flex-wrap gap-2">
                {items.map((s) => (
                  <li>
                    <Tag label={s} />
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>

    <div class="mt-16">
      <SectionHeading number="02.3" title="Formation" as="h2" />
      <ol class="mt-8 divide-y-2 divide-line border-2 border-line">
        {
          formation.map((item) => (
            <li class="grid gap-2 p-5 sm:grid-cols-[6rem_1fr]">
              <Label as="span" muted class="font-bold tabular-nums">
                {item.year}
              </Label>
              <div>
                <Heading as="h3" size="xs">{item.title}</Heading>
                {item.place && (
                  <p class="mt-1 font-mono text-sm text-muted">{item.place}</p>
                )}
                <p class="mt-2 text-sm leading-relaxed text-ink/80">{item.text}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>

    <div class="mt-16">
      <SectionHeading number="02.4" title="Passions" as="h2" />
      <div class="mt-8 grid gap-6 sm:grid-cols-2">
        {passions.map((p) => <PassionCard passion={p} />)}
      </div>
    </div>
  </section>
</Base>
