---
import Base from '../layouts/Base.astro';
import Heading from '../components/Heading.astro';
import Label from '../components/Label.astro';
import Button from '../components/Button.astro';
---

<Base title="404 - Page introuvable" description="Cette page n'existe pas.">
  <section
    class="mx-auto flex min-h-[calc(100dvh-4rem)] max-w-6xl flex-col justify-center px-4 py-16"
  >
    <Label as="p" muted class="tracking-widest">Erreur</Label>

    <Heading
      as="h1"
      size="none"
      class="mt-4 leading-[0.8] tracking-tighter text-[30vw] sm:text-[20rem]"
    >
      4<span class="text-accent">0</span>4
    </Heading>

    <p class="mt-6 max-w-xl text-xl sm:text-2xl leading-snug">
      Cette page n'existe pas - ou plus. Le lien est peut-être cassé.
    </p>

    <div class="mt-10 flex flex-wrap gap-4">
      <Button href="/" variant="solid">← Retour à l'accueil</Button>
      <Button href="/projets">Voir les projets</Button>
    </div>
  </section>
</Base>
