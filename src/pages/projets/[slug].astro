---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import Base from '../../layouts/Base.astro';
import Tag from '../../components/Tag.astro';

export const getStaticPaths = (async () => {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}) satisfies GetStaticPaths;

const { project } = Astro.props;
const { data } = project;
const { Content } = await render(project);
const num = String(data.order).padStart(2, '0');
---

<Base title={data.title} description={data.description} ogImage={data.image}>
  <article class="mx-auto max-w-4xl px-4 py-16">
    <!-- Fil d'ariane -->
    <a href="/projets" class="link-brutal font-mono text-xs uppercase">
      ← Retour aux projets
    </a>

    <!-- En-tête -->
    <header class="mt-8 border-b-2 border-line pb-8">
      <div class="flex items-center gap-4 font-mono text-sm uppercase text-muted">
        <span class="font-bold tabular-nums text-ink">{num}</span>
        {data.date && <span>/ {data.date}</span>}
      </div>

      <h1 class="mt-4 font-display text-5xl sm:text-7xl font-bold uppercase leading-none tracking-tighter">
        {data.title}
      </h1>

      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-ink/80">
        {data.description}
      </p>

      <!-- Stack -->
      <ul class="mt-6 flex flex-wrap gap-2">
        {data.stack.map((s) => <li><Tag label={s} /></li>)}
      </ul>

      <!-- Liens -->
      {
        (data.demo || data.github) && (
          <div class="mt-8 flex flex-wrap gap-4 font-mono text-sm uppercase">
            {data.demo && (
              <a
                href={data.demo}
                target="_blank"
                rel="noopener"
                class="border-2 border-line bg-ink px-5 py-2.5 text-bg transition-colors duration-150 hover:bg-accent hover:text-accent-ink"
              >
                Démo ↗
              </a>
            )}
            {data.github && (
              <a
                href={data.github}
                target="_blank"
                rel="noopener"
                class="border-2 border-line px-5 py-2.5 transition-colors duration-150 hover:bg-accent hover:text-accent-ink"
              >
                GitHub ↗
              </a>
            )}
          </div>
        )
      }
    </header>

    <!-- Visuel -->
    <img
      src={data.image}
      alt={`Aperçu du projet ${data.title}`}
      width="1200"
      height="675"
      class="mt-8 aspect-video w-full border-2 border-line object-cover"
    />

    <!-- Contenu markdown -->
    <div
      class="prose-brutal mt-12 max-w-none"
    >
      <Content />
    </div>
  </article>
</Base>

<style is:global>
  /* Mise en forme minimale du contenu markdown (pas de plugin typography). */
  .prose-brutal :where(h2) {
    font-family: var(--font-display);
    text-transform: uppercase;
    font-size: 1.75rem;
    line-height: 1;
    letter-spacing: -0.02em;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-line);
  }
  .prose-brutal :where(h3) {
    font-family: var(--font-display);
    text-transform: uppercase;
    font-size: 1.25rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose-brutal :where(p) {
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }
  .prose-brutal :where(ul) {
    list-style: none;
    margin-bottom: 1.5rem;
    padding-left: 0;
  }
  .prose-brutal :where(li) {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 0.5rem;
    line-height: 1.6;
  }
  .prose-brutal :where(li)::before {
    content: "→";
    position: absolute;
    left: 0;
    font-family: var(--font-mono);
    color: var(--color-ink);
  }
  .prose-brutal :where(blockquote) {
    border-left: 4px solid var(--color-accent);
    padding-left: 1rem;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--color-muted);
    margin: 1.5rem 0;
  }
  .prose-brutal :where(a) {
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 3px;
  }
</style>
