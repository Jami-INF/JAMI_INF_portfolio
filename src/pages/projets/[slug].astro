---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import Base from '../../layouts/Base.astro';
import Tag from '../../components/Tag.astro';
import Heading from '../../components/Heading.astro';
import Label from '../../components/Label.astro';
import Button from '../../components/Button.astro';
import FramedImage from '../../components/FramedImage.astro';

export const getStaticPaths = (async () => {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}) satisfies GetStaticPaths;

const { project } = Astro.props;
const { data } = project;
const { Content } = await render(project);
const num = String(data.order).padStart(2, '0');
---

<Base title={data.title} description={data.description} ogImage={data.image}>
  <article class="mx-auto max-w-4xl px-4 py-16">
    <!-- Fil d'ariane -->
    <Label as="a" href="/projets" size="xs" class="link-brutal">
      ← Retour aux projets
    </Label>

    <!-- En-tête -->
    <header class="mt-8 border-b-2 border-line pb-8">
      <Label as="div" muted class="flex flex-wrap items-center gap-4">
        <span class="font-bold tabular-nums text-ink">{num}</span>
        {data.date && <span>/ {data.date}</span>}
        {data.ai && (
          <span class="border-2 border-line bg-accent px-2 py-0.5 text-xs font-bold text-accent-ink">
            Conçu avec l'IA
          </span>
        )}
      </Label>

      <Heading as="h1" size="xl" class="mt-4">{data.title}</Heading>

      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-ink/80">
        {data.description}
      </p>

      <!-- Stack -->
      <ul class="mt-6 flex flex-wrap gap-2">
        {data.stack.map((s) => <li><Tag label={s} /></li>)}
      </ul>

      <!-- Liens -->
      {
        (data.demo || data.github) && (
          <div class="mt-8 flex flex-wrap gap-4">
            {data.demo && (
              <Button href={data.demo} variant="solid" size="sm" external>
                Démo ↗
              </Button>
            )}
            {data.github && (
              <Button href={data.github} size="sm" external>
                GitHub ↗
              </Button>
            )}
          </div>
        )
      }
    </header>

    <!-- Visuel -->
    <FramedImage
      src={data.image}
      alt={`Aperçu du projet ${data.title}`}
      eager
      class="mt-8"
    />

    <!-- Contenu markdown -->
    <div
      class="prose-brutal mt-12 max-w-none"
    >
      <Content />
    </div>
  </article>
</Base>
