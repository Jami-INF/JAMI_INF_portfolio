---
import Tag from './Tag.astro';
import Heading from './Heading.astro';
import Label from './Label.astro';
import FramedImage from './FramedImage.astro';

interface Props {
  number: string;
  title: string;
  description: string;
  stack: string[];
  image: string;
  href: string;
  date?: string;
  /** Projet conçu en pilotant l'IA — affiche un badge sur la carte. */
  ai?: boolean;
}
const { number, title, description, stack, image, href, date, ai = false } = Astro.props;
---

<article
  class="group relative flex flex-col border-2 border-line bg-bg transition-transform duration-150 hover:-translate-x-1 hover:-translate-y-1 focus-within:-translate-x-1 focus-within:-translate-y-1"
>
  <Label as="div" size="xs" class="flex items-center justify-between border-b-2 border-line px-4 py-2">
    <span class="font-bold tabular-nums">{number}</span>
    <span class="flex items-center gap-2">
      {ai && (
        <span class="border-2 border-line bg-accent px-1.5 py-0.5 font-bold text-accent-ink">
          IA
        </span>
      )}
      {date && <span class="text-muted">{date}</span>}
    </span>
  </Label>

  <a href={href} class="block border-b-2 border-line" tabindex="-1" aria-hidden="true">
    <FramedImage src={image} frame="none" />
  </a>

  <div class="flex flex-1 flex-col gap-4 p-4">
    <Heading as="h3" size="md">
      <a href={href} class="after:absolute after:inset-0 focus:outline-none">
        {title}
      </a>
    </Heading>

    <p class="text-sm leading-relaxed text-ink/80">{description}</p>

    <ul class="mt-auto flex flex-wrap gap-2 pt-2">
      {stack.map((s) => <li><Tag label={s} /></li>)}
    </ul>

    <div class="flex items-center gap-3 border-t-2 border-line pt-3 font-mono text-sm">
      <span class="link-brutal font-bold">Voir le projet →</span>
    </div>
  </div>
</article>
