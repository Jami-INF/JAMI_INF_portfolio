---
/**
 * Titre de section brutaliste avec numérotation (01, 02…).
 * Le numéro est en monospace, le titre en display XXL.
 */
interface Props {
  number: string; // ex. "01"
  title: string;
  as?: 'h1' | 'h2';
}
const { number, title, as = 'h2' } = Astro.props;
const Tag = as;
---

<div class="flex items-end gap-4 border-b-2 border-line pb-3">
  <span class="font-mono text-sm font-bold text-muted tabular-nums shrink-0">{number}</span>
  <Tag class="font-display text-3xl sm:text-4xl md:text-5xl uppercase leading-none tracking-tight">
    {title}
  </Tag>
</div>
