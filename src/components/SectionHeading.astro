---
/**
 * Titre de section brutaliste avec numérotation (01, 02…).
 * Le numéro est en monospace, le titre en display XXL.
 */
import Heading from './Heading.astro';
import Label from './Label.astro';

interface Props {
  number: string; // ex. "01"
  title: string;
  as?: 'h1' | 'h2';
}
const { number, title, as = 'h2' } = Astro.props;
---

<div class="flex items-end gap-4 border-b-2 border-line pb-3">
  <Label muted class="font-bold tabular-nums shrink-0">{number}</Label>
  <Heading as={as} size="none" class="text-3xl sm:text-4xl md:text-5xl leading-none tracking-tight">
    {title}
  </Heading>
</div>
