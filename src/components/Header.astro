---
import { NAV, SITE } from '../consts';

// Normalise le chemin courant pour l'état actif (sans slash final).
const path = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isActive = (href: string) => {
  const clean = href.replace(/\/+$/, '') || '/';
  return clean === '/' ? path === '/' : path === clean || path.startsWith(clean + '/');
};
---

<header class="border-b-2 border-line bg-bg sticky top-0 z-50">
  <nav
    aria-label="Navigation principale"
    class="mx-auto flex max-w-6xl items-stretch justify-between"
  >
    <a
      href="/"
      class="flex items-center gap-2 border-r-2 border-line px-4 py-4 font-display text-lg font-bold uppercase tracking-tight transition-colors duration-150 hover:bg-accent hover:text-accent-ink"
    >
      <span aria-hidden="true" class="font-mono text-accent-ink bg-ink text-bg px-1.5 py-0.5 text-sm">JI</span>
      <span>{SITE.name}</span>
    </a>

    <ul class="flex items-stretch">
      {
        NAV.filter((item) => item.href !== '/').map((item) => (
          <li class="flex">
            <a
              href={item.href}
              aria-current={isActive(item.href) ? 'page' : undefined}
              class:list={[
                'flex items-center border-l-2 border-line px-3 sm:px-5 font-mono text-xs sm:text-sm uppercase tracking-wide transition-colors duration-150 hover:bg-accent hover:text-accent-ink',
                isActive(item.href) && 'bg-ink text-bg',
              ]}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
