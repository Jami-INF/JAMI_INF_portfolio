---
/**
 * Titre display du design system : Space Grotesk, gras, capitales.
 * `size` couvre les tailles récurrentes du site ; pour un cas unique
 * (hero en vw…), passer `size="none"` et fournir les classes de taille.
 */
type Size = 'xs' | 'sm' | 'md' | 'lg' | 'xl' | 'none';

interface Props {
  as?: keyof HTMLElementTagNameMap;
  size?: Size;
  class?: string;
  [key: string]: unknown;
}

const sizes: Record<Exclude<Size, 'none'>, string> = {
  xs: 'text-xl leading-none tracking-tight',
  sm: 'text-2xl leading-none tracking-tight',
  md: 'text-2xl sm:text-3xl leading-none tracking-tight',
  lg: 'text-3xl sm:text-5xl leading-none tracking-tighter',
  xl: 'text-5xl sm:text-7xl leading-none tracking-tighter',
};

const { as: Tag = 'h2', size = 'md', class: cls, ...rest } = Astro.props;
---

<Tag
  class:list={[
    'font-display font-bold uppercase',
    size !== 'none' && sizes[size],
    cls,
  ]}
  {...rest}
>
  <slot />
</Tag>
