---
/** Carte passion : photo 16:9 en bandeau + titre + texte (page À propos).
    Devient un lien cliquable si `href` est fourni (ex. la galerie photo). */
import type { Passion } from '../data/about';
import Heading from './Heading.astro';
import FramedImage from './FramedImage.astro';

interface Props {
  passion: Passion;
}
const { passion: p } = Astro.props;
const Wrapper = p.href ? 'a' : 'div';
---

<Wrapper
  href={p.href}
  class:list={[
    'block border-2 border-line',
    p.href &&
      'group transition-transform duration-150 hover:-translate-x-1 hover:-translate-y-1 focus-within:-translate-x-1 focus-within:-translate-y-1',
  ]}
>
  {p.image && <FramedImage src={p.image} variant="banner" frame="bottom" />}
  <div class="p-5">
    <Heading as="h3" size="xs">{p.title}</Heading>
    <p class="mt-3 text-sm leading-relaxed text-ink/80">{p.text}</p>
    {p.href && (
      <span class="link-brutal mt-4 inline-block font-mono text-sm font-bold">
        Voir la galerie →
      </span>
    )}
  </div>
</Wrapper>
