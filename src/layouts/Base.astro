---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../consts';

interface Props {
  title?: string;
  description?: string;
  /** Chemin de l'image OG (dans /public) — sinon image par défaut. */
  ogImage?: string;
}

const {
  title,
  description = SITE.description,
  ogImage = SITE.ogImage,
} = Astro.props;

// Titre complet : « Page — Jami Infante » (accueil = titre brut).
const fullTitle = title ? `${title} — ${SITE.name}` : SITE.title;

// URLs absolues pour l'Open Graph (nécessite `site` dans astro.config).
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL(ogImage, Astro.site);
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="fr_FR" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body>
    <!-- Lien d'évitement (accessibilité) -->
    <a
      href="#contenu"
      class="sr-only focus:not-sr-only focus:absolute focus:left-2 focus:top-2 focus:z-50 focus:border-2 focus:border-line focus:bg-accent focus:px-3 focus:py-2 focus:font-mono focus:text-sm"
    >
      Aller au contenu
    </a>

    <Header />

    <main id="contenu" class="flex-1">
      <slot />
    </main>

    <Footer />
  </body>
</html>
